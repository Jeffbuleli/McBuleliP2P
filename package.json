{
  "name": "mcbuleli-p2p",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "node --env-file=.env ./node_modules/.bin/drizzle-kit push --dialect=postgresql --schema=./src/db/schema.ts --url=\"$DATABASE_URL\"",
    "db:push:remote": "./node_modules/.bin/drizzle-kit push --dialect=postgresql --schema=./src/db/schema.ts --url=\"$DATABASE_URL\"",
    "db:push:render": "node scripts/drizzle-push-render.cjs",
    "db:migrate:render": "node scripts/drizzle-migrate-batched.cjs",
    "db:migrate:render:kit": "node scripts/drizzle-migrate-render.cjs",
    "db:studio": "node --env-file=.env ./node_modules/.bin/drizzle-kit studio --dialect=postgresql --schema=./src/db/schema.ts --url=\"$DATABASE_URL\"",
    "verify:binance": "node --env-file=.env scripts/verify-binance.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "ccxt": "^4.5.54",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "next": "16.2.4",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-qr-code": "^2.0.21",
    "technicalindicators": "^3.1.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
