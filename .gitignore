# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# user-uploaded avatars (keep folder placeholder)
/public/uploads/avatars/*
!/public/uploads/avatars/.gitkeep

# misc
.tmp/
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
drizzle-push*.log
migrate-*.log
migrate_*.log

# env files — use `.env` locally (never commit)
.env
.env.*
!.env.example

# Python AI trading service
services/mcbuleli-ai-trading/.venv/
services/mcbuleli-ai-trading/**/__pycache__/
services/mcbuleli-ai-trading/.pytest_cache/
services/mcbuleli-ai-trading/logs/*.jsonl
services/mcbuleli-ai-trading/.env

# Local OpenWA clone (self-hosted gateway — deploy separately)
/OpenWA/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
*.png
!public/**/*.png
!/src/app/icon.png
!/src/app/apple-icon.png

# Godot 4 editor cache
/godot/.godot/
/godot/.import/
/godot/*.tmp

# Local legal scans (RCCM, ID NAT) — see content/legal-private/README.md
/content/legal-private/*
!/content/legal-private/README.md
!/content/legal-private/.gitignore
ID NAT.png
RCCM1.png
RCCM2.png
godot/
godot/
Godot.app/
*.zip
godot/
*.zip
Godot.app/
