# Copy to ops/vps/.env (never commit). Mirror Render Web env + Postgres local.

POSTGRES_USER=mcbuleli
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=mcbuleli

NEXT_PUBLIC_APP_URL=https://mcbuleli.org
DATABASE_URL=postgresql://mcbuleli:change-me-strong-password@db:5432/mcbuleli

JWT_SECRET=
CRON_SECRET=

# Wallet / exchanges
BINANCE_WALLET_API_KEY=
BINANCE_WALLET_API_SECRET=
BINANCE_ENV=live
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
BOT_KEYS_ENCRYPTION_SECRET=
WALLET_AUTOMATION_ENABLED=1
WALLET_AUTO_DEPOSIT_ENABLED=1
WALLET_AUTO_WITHDRAW_ENABLED=1

# Optional: BOT_CRON_INLINE=0 when VPS crontab runs bots-tick
BOT_CRON_INLINE=0

# Jitsi / Academy (same secrets as live VPS)
# JITSI_JWT_SECRET=
# NEXT_PUBLIC_ACADEMY_LIVE_BASE_URL=https://live.mcbuleli.org

# Email, KYC, Turnstile, S3, OpenAI — paste from Render dashboard

# ── PawaPay MoMo (DRC · USD/CDF · Airtel / Orange / M-Pesa) ───────────────────
# Prod only on VPS (token from https://dashboard.pawapay.io/ — not sandbox).
PAWAPAY_API_TOKEN=
PAWAPAY_ENV=production
# PAWAPAY_CALLBACK_SECRET=
# PAWAPAY_CALLBACK_IPS=18.192.208.15,18.195.113.136,3.72.212.107,54.73.125.42,54.155.38.214,54.73.130.113
# Callback URL: https://mcbuleli.org/api/webhooks/pawapay
# FIAT_DEPOSIT_WITHDRAW_PAUSED=true

# FreshPay card (optional)
# FRESHPAY_CARD_API_KEY=
# FRESHPAY_CARD_API_SECRET=
# FRESHPAY_CARD_CALLBACK_SECRET=
