# Used by systemd mcbuleli-ai-relay.service
MODE=SIGNAL_ONLY
INTERVAL_SEC=60
MCBULELI_API_URL=https://mcbuleli.org
MCBULELI_CRON_SECRET=replace-with-same-as-CRON_SECRET
MCBULELI_INSTANCE_ID=
TWITTER_ENABLED=1
TWITTER_BEARER_TOKEN=
X_LLM_ENABLED=1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
SIGNAL_MIN_EDGE=15
X_LLM_BLEND_WEIGHT=0.55
