# Mode: PAPER | SIGNAL_ONLY | LIVE (LIVE disabled unless explicitly enabled in code)
MODE=PAPER

# Binance Futures — leave EMPTY in SIGNAL_ONLY (public OHLCV; keys here cause -2015 if spot-only / wrong IP)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=0

# Engine
SYMBOL=BTC/USDT:USDT
TIMEFRAME=15m
CONFIRM_TIMEFRAME=1h
INTERVAL_SEC=60

# Risk caps
MAX_LEVERAGE=10
MAX_RISK_PCT=2.0
MAX_DAILY_DRAWDOWN_PCT=5.0
MAX_POSITIONS=1
MIN_CONFIDENCE=40
EMERGENCY_STOP=0

# News / sentiment (RSS — no API key required for MVP)
NEWS_RSS_URLS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss
NEWS_MAX_HEADLINES=40
SENTIMENT_PAUSE_THRESHOLD=-0.45
VOLATILITY_PAUSE_ATR_PCT=3.5

# X (Twitter) API v2 — https://developer.x.com/
TWITTER_ENABLED=0
TWITTER_BEARER_TOKEN=
# API Key = Consumer Key, API Secret = Consumer Secret (keep for OAuth apps)
TWITTER_API_KEY=
TWITTER_API_SECRET=
# Optional custom query (default: BTC/bitcoin/crypto, no retweets, English)
# TWITTER_SEARCH_QUERY=(bitcoin OR BTC) -is:retweet lang:en
TWITTER_MAX_POSTS=25

# X → LLM analyst (your crypto analyst prompt; OpenAI-compatible API)
X_LLM_ENABLED=0
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# GPT-5.x → Responses API; gpt-4* → Chat Completions
OPENAI_MODEL=gpt-5.5
# OPENAI_TEMPERATURE=0.1
# OPENAI_TIMEOUT_SEC=90
# X_LLM_BLEND_WEIGHT=0.55
# Weight of LLM vs VADER/RSS when blending sentiment (0–1, default 0.45)
# X_LLM_BLEND_WEIGHT=0.45

# |combined_score| must be > this for LONG/SHORT (default 20). Lower = more trades.
SIGNAL_MIN_EDGE=20

# McBuleli bridge (Phase 2 — optional)
MCBULELI_API_URL=
MCBULELI_CRON_SECRET=
MCBULELI_INSTANCE_ID=

# Logging
LOG_JSONL_PATH=logs/decisions.jsonl
