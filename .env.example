# Copy to `.env` and fill in real values. Never commit secrets.

# PostgreSQL (run migrations in /drizzle — e.g. 0005_wallet_fiat_ledger for USD/CDF pockets + ledger)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/mcbuleli

# Public site URL (avatars + absolute asset URLs on mobile / PWA). No trailing slash.
# NEXT_PUBLIC_APP_URL=https://mcbuleli.org

# Session signing (min 16 characters)
JWT_SECRET=change-me-to-a-long-random-string-min-16-chars

# Cloudflare Turnstile — login + register CAPTCHA (https://dash.cloudflare.com → Turnstile)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Comma-separated extra CORS origins (preview deploys). Production: https://mcbuleli.org only.
# CORS_ALLOWED_ORIGINS=

# ── Academy / Jitsi live (live.mcbuleli.org) ────────────────────────────────
# NEXT_PUBLIC_ACADEMY_LIVE_BASE_URL=https://live.mcbuleli.org
# JITSI_APP_ID=mcbuleli_live
# JITSI_JWT_SECRET=          # identical to Prosody app_secret on VPS
# JITSI_JWT_SUB=live.mcbuleli.org
# JITSI_JWT_TTL_SEC=7200     # JWT lifetime (default 2 h)
# See docs/jitsi-security.md + ops/jitsi/harden-security.sh

# Comma-separated emails that get super_admin on register/login (operations / role management)
# SUPER_ADMIN_EMAILS=ops@example.com

# ── Binance — Wallet USDT (dépôts + retraits auto sur le serveur) ─────────────
# Clés créées sur binance.com (live) ou demo.binance.com (tests).
# Permissions : Reading + Withdrawals (pas Spot/Futures).
BINANCE_WALLET_API_KEY=
BINANCE_WALLET_API_SECRET=
# BINANCE_ENV=live
# BINANCE_RECV_WINDOW=60000
# demo : BINANCE_ENV=demo + BINANCE_API_BASE=https://demo-api.binance.com

# ── Binance — Bots trading (utilisateurs) — PAS dans .env serveur ───────────
# Chaque user connecte ses clés dans l’app (Bots → Démo ou Live).
# Démo = clés demo.binance.com ; Live = clés binance.com. Pas de 2e BINANCE_ENV.

# Encrypt per-user Binance API keys for trading bots (min 32 random chars)
# BOT_KEYS_ENCRYPTION_SECRET=

# Trading bots — server cron (min 12 chars). Render Cron Job: POST /api/internal/bots/tick every 5 min with header x-cron-secret
# AVEC governance — Render Cron Job: POST /api/internal/governance/tick every 10 min (scripts/cron-governance-tick.mjs)
# P2P — Render Cron Job: POST /api/internal/p2p/expire every 5 min (scripts/cron-p2p-expire.mjs)
# P2P_RELEASE_WINDOW_MINUTES=30
# P2P_RELEASE_REMINDER_MINUTES=10
# CRON_SECRET=
# Recommended on Render web service (single instance): BOT_CRON_INLINE=1
# BOT_CRON_INTERVAL_MS=300000
# BOT_CRON_BASE_URL=https://mcbuleli.org

# OKX (server only — Pi deposit address + deposit history / TXID; public PI-USDT ticker needs no key)
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
# OKX_API_BASE=https://www.okx.com
# OKX chain id for Pi deposits (OKX “Deposit” UI / currencies), default "Pi"
# OKX_PI_CHAIN=Pi

# Desk rate: Congolese francs per 1 USD (dashboard CDF estimate from USDT-equivalent total)
# FX_CDF_PER_USD=2850

# Liquidity pool — new deposits OFF by default (use Staking). Set POOL_ENABLED=true to reopen.
# POOL_ENABLED=false

# Staking APR / terms (optional JSON overrides)
# STAKING_USDT_TERMS=[{"days":30,"apr":6},{"days":90,"apr":9},{"days":180,"apr":12}]
# STAKING_PI_TERMS=[{"days":30,"apr":4},{"days":90,"apr":6.5},{"days":180,"apr":9}]

# USDT wallet automation (cron: scripts/cron-wallet-*.mjs → /api/internal/wallet/*)
# WALLET_AUTOMATION_ENABLED=1
# WALLET_AUTO_DEPOSIT_ENABLED=1
# WALLET_AUTO_WITHDRAW_ENABLED=1
# WALLET_CRON_SECRET=          # optional alias; Render crons use CRON_SECRET (same as Web) — docs/wallet-cron-render.md
# WALLET_DEPOSIT_SESSION_MINUTES=30
# WALLET_DEPOSIT_GRACE_MINUTES=90
# WALLET_WITHDRAW_BATCH_MIN_MINUTES=5
# WALLET_WITHDRAW_BATCH_MAX_MINUTES=30

# Business rules
MIN_DEPOSIT_USDT=1
MIN_DEPOSIT_PI=1
# Rolling 24h outbound caps (USDT / Pi external withdrawals)
# WITHDRAWAL_DAILY_MAX_USDT=10000
# WITHDRAWAL_DAILY_MAX_PI=50000
AMOUNT_TOLERANCE=0.00000001

# Custodial fixed-term staking (USDT / PI). APR is fixed at subscription.
# STAKING_MIN_USDT=10
# STAKING_MIN_PI=50
# STAKING_USDT_TERMS=[{"days":30,"apr":4.5},{"days":90,"apr":7},{"days":180,"apr":10}]
# STAKING_PI_TERMS=[{"days":30,"apr":3},{"days":90,"apr":5},{"days":180,"apr":8}]

# P2P marketplace (fiat off-platform, crypto in McBuleli escrow)
# Default (when unset): only CDF & USD as quote currencies; escrow stays USDT/PI. Custodial USD/CDF wallet is never used for P2P.
# Set to ALL or * to allow every P2P_FIAT_CURRENCIES code (EUR, NGN, …).
# NEXT_PUBLIC_P2P_QUOTE_FIATS=CDF,USD
# NEXT_PUBLIC_P2P_QUOTE_FIATS=ALL
# P2P_PAYMENT_WINDOW_MINUTES=45
# P2P_MIN_CRYPTO_USDT=5
# P2P_MIN_CRYPTO_PI=50
# Optional: deduct fee from buyer payout at release (basis points). Requires treasury user UUID.
# P2P_FEE_BPS=50
# P2P_FEE_TREASURY_USER_ID=

# Pause USD/CDF mobile-money deposit & withdraw (UI + API). USDT/Pi unchanged.
# FIAT_DEPOSIT_WITHDRAW_PAUSED=true

# ── FreshPay — Mobile money (USD/CDF MoMo: Airtel, Orange, M-Pesa…) ───────────
# Dashboard field "Merchant ID" + "Merchant Secret" (NOT Merchant Code, NOT card keys).
# Gateway prod: https://paydrc.gofreshbakery.net/api/v5/
# Pay-in body: merchant_id, merchant_secrete, amount, currency, action (debit|credit),
# customer_number, firstname/lastname/e-mail (fixed McBuleli identity in code), reference, method, callback_url
# Callback (encrypted): https://mcbuleli.org/api/webhooks/freshpay
FRESHPAY_MERCHANT_ID=
FRESHPAY_SECRET=
# Callback decryption — ask FreshPay support if not in dashboard (≠ card Callback Secret).
FRESHPAY_AES_KEY=
FRESHPAY_HMAC_KEY=
# FRESHPAY_ENV=production
# FRESHPAY_API_BASE_URL=https://paydrc.gofreshbakery.net/api/v5/
# FRESHPAY_CALLBACK_IPS=

# ── FreshPay — Card (Cybersource hosted checkout) — separate from MoMo above ───
# Not covered by MOKO Afrika PayDRC docs (moko-africa-documentation.vercel.app).
# Dashboard: Cybersource Merchant ID, API Key, API Secret, Callback Secret.
# Prod API: https://card.gofreshpay.com  ·  Sandbox: https://test.card.gofreshpay.com
# FRESHPAY_CARD_MERCHANT_ID=
# FRESHPAY_CARD_API_KEY=
# FRESHPAY_CARD_API_SECRET=
# FRESHPAY_CARD_CALLBACK_SECRET=
# FRESHPAY_CARD_API_BASE_URL=https://card.gofreshpay.com
# FRESHPAY_CARD_ENV=production

# Deposit launch bonus campaign — retired (ledger history kept in DB)

# Academy — test live session (slug test-live-mcbuleli). Off in prod unless staff.
# ACADEMY_TEST_LIVE_ENABLED=false

# Trade module (custodial Futures / simple Options — USDT from wallet balance)
# TRADE_MAX_MARGIN_USDT=10000
# TRADE_MAX_OPTIONS_STAKE_USDT=500

# Pi Browser — production defaults to SameSite=None (Secure) so sessions persist in Pi WebView.
# Override: SESSION_COOKIE_SAMESITE=lax|strict|none
# SESSION_COOKIE_SAMESITE=none

# Pi Network — register https://mcbuleli.org in Pi Developer Portal; validation key at /validation-key.txt
# PI_NETWORK_API_KEY = Pi Platform Mainnet app (Develop → API Key). PI_NETWORK_API_KEY_TEST = linked Pi Testnet app only.
# PI_NETWORK_API_KEY=
# PI_NETWORK_API_KEY_TEST=

# Pi P2P conversion — paid ad boost (U2A)
# NEXT_PUBLIC_PI_P2P_BOOST_AMOUNT=0.1
# PI_P2P_BOOST_DAYS=7

# Pi Browser — wallet top-up amounts (comma-separated Pi). Each number = one pay button / option.
# Example — 7 options: NEXT_PUBLIC_PI_TOPUP_AMOUNTS=10,20,30,50,100,300,500
# Decimals use a dot (10.5). Commas separate options only, not decimals.
# If unset, a single preset uses NEXT_PUBLIC_PI_TEST_PAYMENT_AMOUNT (default 0.1).
# NEXT_PUBLIC_PI_TOPUP_AMOUNTS=10,20,30,50,100,300,500
# NEXT_PUBLIC_PI_TEST_PAYMENT_AMOUNT=0.1

# Pi Browser SDK — set to 1 for testnet/sandbox Pi APIs (required if you test on your own domain with sandbox keys).
# Pages opened at https://sandbox.minepi.com/... auto-use sandbox init even if unset.
# NEXT_PUBLIC_PI_SANDBOX=1
# Deprecated (ignored): was auto-running Pi.authenticate on /login — caused hangs outside Pi Browser.
# NEXT_PUBLIC_PI_AUTO_LOGIN=1

# ── KYC (Didit V3) — https://docs.didit.me/ ──────────────────────────────────
# KYC_ENABLED=true
# KYC_GLOBAL=true              # default: all profile countries (not OTHER) via Didit
# KYC_REQUIRED_COUNTRIES=...   # only when KYC_GLOBAL=false (legacy corridor list)
# DIDIT_API_KEY=...          # POST /auth/v2/programmatic/verify-email/ → application.api_key
# DIDIT_WORKFLOW_ID=...      # POST /v3/workflows/ → workflow_id (OCR + LIVENESS + FACE_MATCH)
# DIDIT_WEBHOOK_SECRET=...   # POST /v3/webhook/destinations/ → secret_shared_key
# Webhook URL: https://mcbuleli.org/api/webhooks/didit
# Register destination with webhook_version: "v3", subscribed_events: ["status.updated", "data.updated"]
# Never expose DIDIT_API_KEY to the browser — sessions are created server-side only.

# ── McB utility token (Phase 3 — BEP-20 on BSC, chainId 56) ───────────────────
# MCB_TOKEN_CONTRACT = token CONTRACT address from Remix deploy (NOT your MetaMask wallet)
# MCB_TOKEN_CONTRACT=0x...
# MCB_CLAIM_ENABLED=true
# See docs/mcb-token-phase3.md

# ── Email (Resend — mcbuleli.org domain) ────────────────────────────────────
# https://resend.com — domain mcbuleli.org must show Verified in Resend dashboard
# RESEND_API_KEY=re_...              # API key (Settings → API Keys)
# AUTH_EMAIL_FROM=McBuleli <noreply@mcbuleli.org>
# AUTH_EMAIL_REPLY_TO=hi@mcbuleli.org   # optional — defaults to hi@mcbuleli.org
# Images: https://mcbuleli.org/brand/logo.png and /email/*.png (see docs/email-resend.md)
# RESEND_USE_TEMPLATES=false         # default — app sends inline HTML with hosted PNG URLs
# RESEND_USE_TEMPLATES=true          # not recommended — uses dashboard templates instead of inline HTML
# RESEND_ALLOW_SEND=false            # local dev: do NOT call Resend API (saves Free quota). Prod: omit or true
# Full catalog: docs/email-resend.md
# Optional template ID overrides (default = alias below):
# RESEND_TEMPLATE_VERIFY_FR=mcbuleli-verify-fr
# RESEND_TEMPLATE_RESET_FR=mcbuleli-reset-fr
# RESEND_TEMPLATE_EMAIL_CHANGE_FR=mcbuleli-email-change-fr
# RESEND_TEMPLATE_EMAIL_ALERT_FR=mcbuleli-email-alert-fr
# RESEND_TEMPLATE_PASSWORD_CHANGED_FR=mcbuleli-password-changed-fr
# (same _EN suffix for English templates)
# Sync templates once: npm run resend:sync-templates  (38 templates — auth + crypto)
# NEXT_PUBLIC_APP_URL = prod URL for CTA links; EMAIL_ASSET_BASE_URL = prod URL for images
#
# Flows: register verify · resend verify · forgot password · email change confirm
#        · email change alert (old address) · password changed alert
#
# ── Account security (TOTP, passkeys, WhatsApp recovery) ────────────────────
# WEBAUTHN_RP_ID=mcbuleli.org
# WEBAUTHN_ORIGIN=https://mcbuleli.org
# ── OpenWA (self-hosted WhatsApp gateway) ───────────────────────────────────
# Repo: https://github.com/rmyndharis/OpenWA
#
# Local / dev:
#   git clone https://github.com/rmyndharis/OpenWA.git && cd OpenWA
#   npm install && npm run dev
#   Dashboard: http://localhost:2886
#   API base:  http://localhost:2785        (McBuleli appends /api/…)
#   Swagger:   http://localhost:2785/api/docs
#
# Docker:
#   docker compose up -d   (or docker compose -f docker-compose.dev.yml up -d)
#
# Setup (Dashboard or curl):
#   1. Create API key → OPENWA_API_KEY
#   2. POST /api/sessions → scan QR → note session id → OPENWA_SESSION_ID
#   3. Register webhook on that session:
#        POST /api/sessions/{sessionId}/webhooks
#        url: https://mcbuleli.org/api/webhooks/openwa/inbound
#        events: ["message.received"]
#        secret: (same as OPENWA_WEBHOOK_SECRET)
#   4. OPENWA_MCBULELI_NUMBER optional — auto-read from session.phone when status is ready/connected
#
# OPENWA_API_BASE=http://localhost:2785
# OPENWA_API_KEY=
# OPENWA_SESSION_ID=
# OPENWA_MCBULELI_NUMBER=243...
# OPENWA_WEBHOOK_SECRET=

# Pi Developer Portal — Pi Network Mainnet app: register https://mcbuleli.org — Pi always fetches:
# https://mcbuleli.org/validation-key.txt  (body = exact key string from portal)
# PI_DOMAIN_VALIDATION_KEY=paste-mainnet-key-from-portal

# Pi Developer Portal — Pi Network Testnet app: register https://mcbulelip2p-1snq.onrender.com — same filename:
# https://mcbulelip2p-1snq.onrender.com/validation-key.txt  (body = Testnet key; Host *.onrender.com uses PI_DOMAIN_VALIDATION_KEY_TEST automatically)
# PI_DOMAIN_VALIDATION_KEY_TEST=paste-testnet-key-from-portal
# Optional: comma-separated hosts that must use the Testnet key at /validation-key.txt (overrides defaults)
# PI_VALIDATION_KEY_TEST_HOSTS=mcbulelip2p-1snq.onrender.com

# Alternate path (same Testnet key): /validation-key-test.txt — optional

# ── Community Hub ─────────────────────────────────────────────────────────────
# COMMUNITY_ENABLED=true
# Cloudflare R2 — images communauté (presigned upload, pas de binaire sur Render)
# @see https://developers.cloudflare.com/r2/
# COMMUNITY_R2_BUCKET=mcbuleli-community
# COMMUNITY_R2_ACCOUNT_ID=
# COMMUNITY_R2_ACCESS_KEY_ID=
# COMMUNITY_R2_SECRET_ACCESS_KEY=
# COMMUNITY_R2_PUBLIC_BASE_URL=https://media.mcbuleli.org
# CORS sur le bucket R2 : autoriser PUT depuis https://mcbuleli.org (et Render preview)
