# PostgreSQL (local: port 5432, or Neon/Render/Supabase connection string on Vercel)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/mcbuleli

# Session signing (min 16 characters)
JWT_SECRET=change-me-to-a-long-random-string

# Binance Spot API (server only — never expose to the client)
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Optional: https://testnet.binance.vision for testing
# BINANCE_API_BASE=https://api.binance.com

# OKX (v5) — key, secret, passphrase
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
# OKX_API_BASE=https://www.okx.com

# Business rules
MIN_DEPOSIT_USDT=1
MIN_WITHDRAW_USDT=5
AMOUNT_TOLERANCE=0.00000001
