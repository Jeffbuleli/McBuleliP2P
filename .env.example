# Copy to `.env` and fill in real values. Never commit secrets.

# PostgreSQL (run migrations in /drizzle — e.g. 0005_wallet_fiat_ledger for USD/CDF pockets + ledger)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/mcbuleli

# Public site URL (avatars + absolute asset URLs on mobile / PWA). No trailing slash.
# NEXT_PUBLIC_APP_URL=https://mcbuleli.org

# Session signing (min 16 characters)
JWT_SECRET=change-me-to-a-long-random-string-min-16-chars

# Comma-separated emails that get super_admin on register/login (operations / role management)
# SUPER_ADMIN_EMAILS=ops@example.com

# ── Binance A) Plateforme (serveur) — dépôts USDT uniquement ─────────────────
# Une seule paire BINANCE_API_* + un seul BINANCE_ENV à la fois (live OU demo).
# Prod réel : BINANCE_ENV=live (ou omis) + clés créées sur binance.com.
BINANCE_API_KEY=
BINANCE_API_SECRET=
# BINANCE_RECV_WINDOW=60000
# BINANCE_ENV=live
# demo (staging / tests dépôts plateforme) : clés demo.binance.com + BINANCE_ENV=demo
# BINANCE_TESTNET=1
# BINANCE_API_BASE=https://demo-api.binance.com
# live (défaut si BINANCE_ENV omis) :
# BINANCE_API_BASE=https://api.binance.com
#
# ── Binance B) Bots trading (utilisateurs) — indépendant de BINANCE_ENV ───────
# Chaque user connecte ses clés dans l’app (Bots → Démo ou Live).
# Démo = clés demo.binance.com ; Live = clés binance.com. Pas de 2e BINANCE_ENV.

# Encrypt per-user Binance API keys for trading bots (min 32 random chars)
# BOT_KEYS_ENCRYPTION_SECRET=

# Trading bots — server cron (min 12 chars). Render Cron Job: POST /api/internal/bots/tick every 5 min with header x-cron-secret
# CRON_SECRET=
# Recommended on Render web service (single instance): BOT_CRON_INLINE=1
# BOT_CRON_INTERVAL_MS=300000
# BOT_CRON_BASE_URL=https://mcbuleli.org

# OKX (server only — Pi deposit address + deposit history / TXID; public PI-USDT ticker needs no key)
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
# OKX_API_BASE=https://www.okx.com
# OKX chain id for Pi deposits (OKX “Deposit” UI / currencies), default "Pi"
# OKX_PI_CHAIN=Pi

# Desk rate: Congolese francs per 1 USD (dashboard CDF estimate from USDT-equivalent total)
# FX_CDF_PER_USD=2850

# Business rules
MIN_DEPOSIT_USDT=1
MIN_DEPOSIT_PI=1
AMOUNT_TOLERANCE=0.00000001

# Custodial fixed-term staking (USDT / PI). APR is fixed at subscription.
# STAKING_MIN_USDT=10
# STAKING_MIN_PI=50
# STAKING_USDT_TERMS=[{"days":30,"apr":4.5},{"days":90,"apr":7},{"days":180,"apr":10}]
# STAKING_PI_TERMS=[{"days":30,"apr":3},{"days":90,"apr":5},{"days":180,"apr":8}]

# P2P marketplace (fiat off-platform, crypto in McBuleli escrow)
# Default (when unset): only CDF & USD as quote currencies; escrow stays USDT/PI. Custodial USD/CDF wallet is never used for P2P.
# Set to ALL or * to allow every P2P_FIAT_CURRENCIES code (EUR, NGN, …).
# NEXT_PUBLIC_P2P_QUOTE_FIATS=CDF,USD
# NEXT_PUBLIC_P2P_QUOTE_FIATS=ALL
# P2P_PAYMENT_WINDOW_MINUTES=45
# P2P_MIN_CRYPTO_USDT=5
# P2P_MIN_CRYPTO_PI=50
# Optional: deduct fee from buyer payout at release (basis points). Requires treasury user UUID.
# P2P_FEE_BPS=50
# P2P_FEE_TREASURY_USER_ID=

# Pause USD/CDF mobile-money deposit & withdraw (UI + API). USDT/Pi unchanged.
# FIAT_DEPOSIT_WITHDRAW_PAUSED=true

# PawaPay — fiat ↔ USDT (CDF / USD only). Callback URL (dashboard): https://mcbuleli.org/api/webhooks/pawapay
# Optional metadata on initiate deposit: userId (UUID), usdtAmount (string). If usdtAmount omitted, conversion uses:
PAWAPAY_CDF_PER_USDT=
PAWAPAY_USD_PER_USDT=

# Trade module (custodial Futures / simple Options — USDT from wallet balance)
# TRADE_MAX_MARGIN_USDT=10000
# TRADE_MAX_OPTIONS_STAKE_USDT=500

# Pi Browser — production defaults to SameSite=None (Secure) so sessions persist in Pi WebView.
# Override: SESSION_COOKIE_SAMESITE=lax|strict|none
# SESSION_COOKIE_SAMESITE=none

# Pi Network — register https://mcbuleli.org in Pi Developer Portal; validation key at /validation-key.txt
# PI_NETWORK_API_KEY = Pi Platform Mainnet app (Develop → API Key). PI_NETWORK_API_KEY_TEST = linked Pi Testnet app only.
# PI_NETWORK_API_KEY=
# PI_NETWORK_API_KEY_TEST=

# Pi P2P conversion — paid ad boost (U2A)
# NEXT_PUBLIC_PI_P2P_BOOST_AMOUNT=0.1
# PI_P2P_BOOST_DAYS=7

# Pi Browser — wallet top-up amounts (comma-separated Pi). Each number = one pay button / option.
# Example — 7 options: NEXT_PUBLIC_PI_TOPUP_AMOUNTS=10,20,30,50,100,300,500
# Decimals use a dot (10.5). Commas separate options only, not decimals.
# If unset, a single preset uses NEXT_PUBLIC_PI_TEST_PAYMENT_AMOUNT (default 0.1).
# NEXT_PUBLIC_PI_TOPUP_AMOUNTS=10,20,30,50,100,300,500
# NEXT_PUBLIC_PI_TEST_PAYMENT_AMOUNT=0.1

# Pi Browser SDK — set to 1 for testnet/sandbox Pi APIs (required if you test on your own domain with sandbox keys).
# Pages opened at https://sandbox.minepi.com/... auto-use sandbox init even if unset.
# NEXT_PUBLIC_PI_SANDBOX=1
# Deprecated (ignored): was auto-running Pi.authenticate on /login — caused hangs outside Pi Browser.
# NEXT_PUBLIC_PI_AUTO_LOGIN=1

# ── KYC (MetaMap) — https://docs.metamap.com/ ────────────────────────────────
# KYC_ENABLED=true
# KYC_REQUIRED_COUNTRIES=CD,RW,TZ,BI,UG,KE,CG,CM,NG,GH,SN,CI
# NEXT_PUBLIC_METAMAP_CLIENT_ID=your_client_id
# NEXT_PUBLIC_METAMAP_FLOW_ID=your_flow_id
# METAMAP_CLIENT_SECRET=your_client_secret
# METAMAP_WEBHOOK_SECRET=your_webhook_secret_min_16_chars
# Webhook URL (MetaMap dashboard): https://mcbuleli.org/api/webhooks/metamap

# Pi Developer Portal — Pi Network Mainnet app: register https://mcbuleli.org — Pi always fetches:
# https://mcbuleli.org/validation-key.txt  (body = exact key string from portal)
# PI_DOMAIN_VALIDATION_KEY=paste-mainnet-key-from-portal

# Pi Developer Portal — Pi Network Testnet app: register https://mcbulelip2p-1snq.onrender.com — same filename:
# https://mcbulelip2p-1snq.onrender.com/validation-key.txt  (body = Testnet key; Host *.onrender.com uses PI_DOMAIN_VALIDATION_KEY_TEST automatically)
# PI_DOMAIN_VALIDATION_KEY_TEST=paste-testnet-key-from-portal
# Optional: comma-separated hosts that must use the Testnet key at /validation-key.txt (overrides defaults)
# PI_VALIDATION_KEY_TEST_HOSTS=mcbulelip2p-1snq.onrender.com

# Alternate path (same Testnet key): /validation-key-test.txt — optional
